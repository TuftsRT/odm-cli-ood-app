---
batch_connect:
  template: "basic"
  conn_params:
    - "output_log"
    - "working_dir"
script:
  wall_time: <%= num_hours.to_i * 3600 %>
  native:
    - "--cpus-per-task=<%= num_cores %>"
    - "--mem=<%= memory_ram %>"
    - "--nodes=1"
    - "--ntasks=1"
    - "--partition=batch"
<% if send_email == "1" %>
<% if alt_email == "" %>
  email: "<%= ENV['USER'] %>@tufts.edu"
<% else %>
  email: "<%= alt_email %>"
<% end %>
  email_on_started: true
  email_on_terminated: true
<% end %>
