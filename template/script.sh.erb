    <% if context.orthophoto_cutline == "1" %>--orthophoto-cutline \<% else %>\<% end %>
    <% if context.tiles == "1" %>--tiles \<% else %>\<% end %>
    <% if context.three_d_tiles == "1" %>--3d-tiles \<% else %>\<% end %>
    <% if context.rolling_shutter == "1" %>--rolling-shutter \<% else %>\<% end %>
    --rolling-shutter-readout <%= context.rolling_shutter_readout.to_i %> \
    <% if context.build_overviews == "1" %>--build-overviews \<% else %>\<% end %>
    <% if context.cog == "1" %>--cog \<% else %>\<% end %>
    <% if context.copy_to != "" %>--copy-to <%= context.copy_to %> \<% else %>\<% end %>
    --video-limit <%= context.video_limit.to_i %> \
    --video-resolution <%= context.video_resolution.to_i %> \
    --split <%= context.split.to_i %> \
    --split-overlap <%= context.split_overlap.to_i %> \
    <% if context.split_image_groups != "" %>--split-image-groups <%= context.split_image_groups %> \<% else %>\<% end %>
    <% if context.sm_no_align == "1" %>--sm-no-align \<% else %>\<% end %>
    --merge <%= context.merge %> \
    <% if context.force_gps == "1" %>--force-gps \<% else %>\<% end %>
    --gps-accuracy <%= context.gps_accuracy.to_f %> \
    <% if context.optimize_disk_space == "1" %>--optimize-disk-space \<% else %>\<% end %>
    <% if context.pc_rectify == "1" %>--pc-rectify \<% else %>\<% end %>
    --primary-band <%= context.primary_band %> \
    <% if context.skip_band_alignment == "1" %>--skip-band-alignment \<% else %>\<% end %>
