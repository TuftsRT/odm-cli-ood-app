    <% if context.texturing_keep_unseen_faces == "1" %>--texturing-keep-unseen-faces \<% else %>\<% end %>
    <% if context.texturing_single_material == "1" %>--texturing-single-material \<% else %>\<% end %>
    <% if context.gltf == "1" %>--gltf \<% else %>\<% end %>
    <% if context.gcp != "" %>--gcp <%= context.gcp %> \<% else %>\<% end %>
    <% if context.geo != "" %>--geo <%= context.geo %> \<% else %>\<% end %>
    <% if context.align != "" %>--align <%= context.align %> \<% else %>\<% end %>
    <% if context.use_exif == "1" %>--use-exif \<% else %>\<% end %>
    <% if context.dtm == "1" %>--dtm \<% else %>\<% end %>
    <% if context.dsm == "1" %>--dsm \<% else %>\<% end %>
    --dem-gapfill-steps <%= context.dem_gapfill_steps.to_i %> \
    --dem-resolution <%= context.dem_resolution.to_f %> \
    --dem-decimation <%= context.dem_decimation.to_i %> \
    <% if context.dem_euclidean_map == "1" %>--dem-euclidean-map \<% else %>\<% end %>
    --orthophoto-resolution <%= context.orthophoto_resolution.to_f %> \
